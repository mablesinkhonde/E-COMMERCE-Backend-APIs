# MongoDB Connection String - REQUIRED for API functionality
# For local MongoDB: mongodb://localhost:27017/shophub
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/shophub?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/shophub

# JWT Secret Key - Change this to a random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration Time
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development

# NOTE: The app will initialize without MONGODB_URI, but API routes will fail until it's configured
